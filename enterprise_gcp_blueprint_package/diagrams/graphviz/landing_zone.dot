digraph G {
  graph [rankdir=LR, bgcolor="white", fontname="Arial", labelloc="t", label="Google Cloud Landing Zone and Shared VPC", fontsize=20];
  node [shape=box, style="rounded,filled", fillcolor="#E8F0FE", color="#1A73E8", fontname="Arial", fontsize=11];
  edge [color="#5F6368", fontname="Arial", fontsize=9];

  Org [label="Google Cloud Organization"];
  Platform [label="Platform Folder"];
  Security [label="Security Folder"];
  Data [label="Data Domains Folder"];
  NonProd [label="Non-Prod Folder"];
  Prod [label="Production Folder"];
  NetHost [label="Host Project
Shared VPC"];
  SecProj [label="Security Project
SCC | KMS | SIEM"];
  LogProj [label="Logging Project"];
  DomProj [label="Domain Service Projects"];
  Interconnect [label="Cloud Interconnect
VPN"];
  PSC [label="Private Service Connect"];
  VPCSC [label="VPC Service Controls"];
  Org -> Platform; Org -> Security; Org -> Data; Org -> NonProd; Org -> Prod;
  Platform -> NetHost; Security -> SecProj; Security -> LogProj; Data -> DomProj;
  Interconnect -> NetHost; NetHost -> PSC; PSC -> DomProj; VPCSC -> DomProj [style=dashed];

}
